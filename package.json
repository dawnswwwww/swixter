{
  "name": "swixter",
  "version": "0.1.1",
  "description": "CLI tool for managing AI coding assistant configurations - easily switch between providers (Claude Code, Codex, Continue) with Anthropic, Ollama, or custom APIs",
  "main": "dist/cli/index.js",
  "module": "dist/cli/index.js",
  "type": "module",
  "bin": {
    "swixter": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bun run build:ui && bun build src/cli/index.ts --outdir dist/cli --target bun --standalone",
    "build:ui": "cd ui && bun install && bun run build && mkdir -p ../dist/ui && cp -r dist/* ../dist/ui/",
    "build:cli": "bun build src/cli/index.ts --outdir dist/cli --target bun --standalone",
    "cli": "bun src/cli/index.ts",
    "cli:dev": "bun --hot src/cli/index.ts",
    "ui:dev": "cd ui && bun run dev",
    "test": "bun test",
    "test:e2e": "bash test/e2e-docker.sh",
    "preversion": "bun test",
    "version": "node scripts/sync-version.js && git add src/constants/meta.ts",
    "postversion": "git push --follow-tags",
    "release": "npm version",
    "release:patch": "npm version patch",
    "release:minor": "npm version minor",
    "release:major": "npm version major"
  },
  "keywords": [
    "claude",
    "claude-code",
    "claude-ai",
    "codex",
    "continue",
    "ai",
    "llm",
    "config",
    "configuration",
    "manager",
    "cli",
    "tool",
    "anthropic",
    "ollama",
    "qwen",
    "provider",
    "switch",
    "api-key",
    "openai-compatible",
    "ai-assistant",
    "code-assistant",
    "developer-tools"
  ],
  "author": "dawnswwwww",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dawnswwwww/swixter.git"
  },
  "bugs": {
    "url": "https://github.com/dawnswwwww/swixter/issues"
  },
  "homepage": "https://github.com/dawnswwwww/swixter#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.10.1",
    "@types/semver": "^7.7.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "clsx": "^2.1.1",
    "js-yaml": "^4.1.1",
    "picocolors": "^1.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1",
    "semver": "^7.7.4",
    "smol-toml": "^1.5.2",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.1.12"
  }
}
