{
  "name": "swixter",
  "version": "0.1.7",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/cli",
    "packages/website",
    "packages/docs"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "build:cli": "bun run --filter 'swixter' build",
    "dev:website": "bun run --filter 'swixter-website' dev",
    "dev:docs": "bun run --filter 'swixter-docs' dev",
    "build:website": "bun run --filter 'swixter-website' build",
    "build:docs": "bun run --filter 'swixter-docs' build",
    "test": "bun run --filter 'swixter' test",
    "test:e2e": "cd packages/cli && bun run test:e2e",
    "cli": "bun run --filter 'swixter' cli",
    "cli:dev": "bun run --filter 'swixter' cli:dev",
    "ui:dev": "bun run --filter 'swixter' ui:dev",
    "preversion": "bun test",
    "version": "node scripts/sync-versions.js && git add packages/*/package.json packages/cli/src/constants/meta.ts",
    "postversion": "git push --follow-tags",
    "release:patch": "npm version patch",
    "release:minor": "npm version minor",
    "release:major": "npm version major"
  },
  "author": "dawnswwwww",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dawnswwwww/swixter.git"
  },
  "bugs": {
    "url": "https://github.com/dawnswwwww/swixter/issues"
  }
}
