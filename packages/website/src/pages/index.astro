---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <nav class="nav">
    <div class="container nav-inner">
      <a href="/" class="logo">
        <span class="logo-icon">&#x25C8;</span>
        <span class="logo-text">Swixter</span>
      </a>
      <div class="nav-links">
        <a href="https://docs.swixter.cc">Docs</a>
        <a href="https://github.com/dawnswwwww/swixter">GitHub</a>
        <a href="https://www.npmjs.com/package/swixter">npm</a>
      </div>
    </div>
  </nav>

  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="container">
        <p class="hero-badge">v{import.meta.env.PUBLIC_VERSION ?? '0.1.6'}</p>
        <h1 class="hero-title">Swixter</h1>
        <p class="hero-desc">
          Manage AI coding assistant configurations with ease.<br />
          Switch providers, sync settings, and keep your tools in order.
        </p>
        <div class="hero-install">
          <code class="install-cmd">npm install -g swixter</code>
          <button class="copy-btn" data-copy="npm install -g swixter" type="button">Copy</button>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="features">
      <div class="container">
        <h2 class="section-title">Why Swixter?</h2>
        <div class="features-grid">
          <article class="feature-card">
            <div class="feature-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 3H5a2 2 0 0 0-2 2v3"/><path d="M21 8V5a2 2 0 0 0-2-2h-3"/><path d="M3 16v3a2 2 0 0 0 2 2h3"/><path d="M16 21h3a2 2 0 0 0 2-2v-3"/><circle cx="12" cy="12" r="3"/></svg>
            </div>
            <h3 class="feature-title">Switch Providers Instantly</h3>
            <p class="feature-desc">One command to switch between Anthropic, Ollama, OpenAI-compatible, and custom providers. No more editing config files by hand.</p>
          </article>

          <article class="feature-card">
            <div class="feature-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" x2="16" y1="21" y2="21"/><line x1="12" x2="12" y1="17" y2="21"/></svg>
            </div>
            <h3 class="feature-title">Multi-Tool Support</h3>
            <p class="feature-desc">Works with Claude Code, Codex, and Continue.dev. One profile applies across all your AI coding tools.</p>
          </article>

          <article class="feature-card">
            <div class="feature-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/></svg>
            </div>
            <h3 class="feature-title">Cloud Sync</h3>
            <p class="feature-desc">Sync your profiles across machines. Set up once, use everywhere. Your config follows you.</p>
          </article>

          <article class="feature-card">
            <div class="feature-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 17 10 11 4 5"/><line x1="12" x2="20" y1="19" y2="19"/></svg>
            </div>
            <h3 class="feature-title">CLI-First Design</h3>
            <p class="feature-desc">Terminal-native with interactive prompts, shell completions, and a local Web UI. Built for developers who live in the command line.</p>
          </article>
        </div>
      </div>
    </section>

    <!-- Quick Example -->
    <section class="example">
      <div class="container">
        <h2 class="section-title">Get Started in 30 Seconds</h2>
        <div class="code-block">
          <div class="code-header">
            <span class="code-label">Terminal</span>
          </div>
          <pre><code><span class="prompt">$</span> npm install -g swixter
<span class="prompt">$</span> swixter claude create my-profile
<span class="prompt">$</span> swixter claude switch my-profile
<span class="prompt">$</span> swixter claude apply
<span class="prompt">$</span> claude  <span class="comment"># ready to go</span></code></pre>
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container footer-inner">
      <p class="footer-copy">Swixter &mdash; Open source under MIT License.</p>
      <div class="footer-links">
        <a href="https://github.com/dawnswwwww/swixter">GitHub</a>
        <a href="https://www.npmjs.com/package/swixter">npm</a>
        <a href="https://docs.swixter.cc">Documentation</a>
      </div>
    </div>
  </footer>
</Layout>

<style>
  /* Nav */
  .nav {
    border-bottom: 1px solid var(--color-outline-variant);
    background: var(--color-surface-lowest);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--color-on-bg);
    font-family: var(--font-label);
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .logo-icon {
    color: var(--color-primary);
    font-size: 18px;
  }

  .nav-links {
    display: flex;
    gap: 24px;
    align-items: center;
  }

  .nav-links a {
    color: var(--color-on-surface-variant);
    font-size: 14px;
    font-weight: 500;
  }

  .nav-links a:hover {
    color: var(--color-primary);
    opacity: 1;
  }

  /* Hero */
  .hero {
    padding: 120px 0 80px;
    text-align: center;
  }

  .hero-badge {
    display: inline-block;
    font-family: var(--font-label);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-primary);
    background: rgba(216, 198, 3, 0.1);
    border: 1px solid rgba(216, 198, 3, 0.25);
    border-radius: 9999px;
    padding: 4px 12px;
    margin-bottom: 24px;
  }

  .hero-title {
    font-size: 64px;
    margin-bottom: 20px;
    color: var(--color-primary);
  }

  .hero-desc {
    font-size: 18px;
    color: var(--color-on-surface-variant);
    max-width: 560px;
    margin: 0 auto 36px;
    line-height: 1.7;
  }

  .hero-install {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--color-surface);
    border: 1px solid var(--color-outline-variant);
    border-radius: var(--radius);
    padding: 8px 8px 8px 20px;
  }

  .install-cmd {
    font-family: var(--font-code);
    font-size: 14px;
    color: var(--color-on-bg);
  }

  .copy-btn {
    font-family: var(--font-label);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-bg);
    background: var(--color-primary);
    border: none;
    border-radius: var(--radius-sm);
    padding: 8px 16px;
    cursor: pointer;
    transition: background 0.2s;
  }

  .copy-btn:hover {
    background: var(--color-primary-dim);
  }

  .copy-btn.copied {
    background: var(--color-tertiary);
  }

  /* Sections */
  .section-title {
    text-align: center;
    margin-bottom: 48px;
    color: var(--color-on-bg);
  }

  /* Features */
  .features {
    padding: 80px 0;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 24px;
    max-width: var(--container-max);
  }

  .feature-card {
    background: var(--color-surface);
    border: 1px solid var(--color-outline-variant);
    border-radius: var(--radius);
    padding: 28px;
    transition: border-color 0.2s;
  }

  .feature-card:hover {
    border-color: var(--color-primary);
  }

  .feature-icon {
    color: var(--color-primary);
    margin-bottom: 16px;
  }

  .feature-title {
    font-size: 16px;
    font-weight: 600;
    margin-bottom: 8px;
    color: var(--color-on-bg);
  }

  .feature-desc {
    font-size: 14px;
    color: var(--color-on-surface-variant);
    line-height: 1.7;
  }

  /* Code Example */
  .example {
    padding: 80px 0 120px;
  }

  .code-block {
    max-width: 640px;
    margin: 0 auto;
    background: var(--color-surface-lowest);
    border: 1px solid var(--color-outline-variant);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .code-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 16px;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-outline-variant);
  }

  .code-label {
    font-family: var(--font-label);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-on-surface-variant);
  }

  .code-block pre {
    padding: 20px;
    overflow-x: auto;
  }

  .code-block code {
    line-height: 1.8;
    color: var(--color-on-bg);
  }

  .prompt {
    color: var(--color-tertiary);
    user-select: none;
  }

  .comment {
    color: var(--color-outline);
  }

  /* Footer */
  .footer {
    border-top: 1px solid var(--color-outline-variant);
    padding: 32px 0;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
  }

  .footer-copy {
    font-size: 13px;
    color: var(--color-outline);
  }

  .footer-links {
    display: flex;
    gap: 20px;
  }

  .footer-links a {
    font-size: 13px;
    color: var(--color-on-surface-variant);
  }

  .footer-links a:hover {
    color: var(--color-primary);
    opacity: 1;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero {
      padding: 80px 0 48px;
    }

    .hero-title {
      font-size: 40px;
    }

    .hero-desc {
      font-size: 16px;
    }

    .hero-install {
      flex-direction: column;
      padding: 16px;
      gap: 12px;
    }

    .features-grid {
      grid-template-columns: 1fr;
    }

    .footer-inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>

<script>
  // Minimal clipboard copy (only JS on page)
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const text = btn.dataset.copy;
      if (!text) return;
      try {
        await navigator.clipboard.writeText(text);
        btn.textContent = 'Copied!';
        btn.classList.add('copied');
        setTimeout(() => {
          btn.textContent = 'Copy';
          btn.classList.remove('copied');
        }, 2000);
      } catch {
        // Fallback for older browsers
        const ta = document.createElement('textarea');
        ta.value = text;
        ta.style.position = 'fixed';
        ta.style.opacity = '0';
        document.body.appendChild(ta);
        ta.select();
        document.execCommand('copy');
        document.body.removeChild(ta);
        btn.textContent = 'Copied!';
        btn.classList.add('copied');
        setTimeout(() => {
          btn.textContent = 'Copy';
          btn.classList.remove('copied');
        }, 2000);
      }
    });
  });
</script>
